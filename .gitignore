__pycache__/
*.pyc
*.pyo

# User data (sensitive)
# Note: Keeping the history file for demo purposes
# In production, you might want to ignore this
# prompts-history.txt
release/

# Frame runtime artifacts (staged spec / agent-dispatch prompts — regenerated)
.frame/runtime/

# Frame implement-mode permissions (written on every autonomous dispatch — regenerated)
.frame/implement-permissions.json

# Frame spec-knowledge index — derived, rebuilt via ensureFresh (never track)
.frame/index/

# Frame orchestration artifacts (materialized on every orchestration start — regenerated)
.frame/bin/*.js
.frame/orchestration/

# Frame durable-write artifacts (src/main/fsSafe.js) — the .bak of the last good
# copy, the .tmp mid-write scratch, and any .corrupt-<ts> preserved on recovery.
# All local crash-safety state, regenerated on the next write; never committed.
*.bak
*.tmp
*.corrupt-*

#Walkthroughs
WALKTHROUGH/*.p8
RELEASE.local.md

# Marketing / growth — local-only, not for GitHub
marketing/

# Pitch deck PDF intermediates (kept locally, not committed)
pitch-assets/pdf/

# Orientation eval transcripts/diffs — bulky, local-only (summary lives in scripts/eval/README.md)
scripts/eval/results/
